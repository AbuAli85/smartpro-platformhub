{
  "name": "smartpro-platformhub",
  "private": true,
  "description": "SmartPRO platform — scripts and packages",
  "scripts": {
    "orchestration:list-ready": "npx --yes tsx scripts/list-ready-for-ai-issues.ts",
    "publish-issues": "npx --yes tsx scripts/publish-issues.ts",
    "migrate": "npx --yes tsx scripts/run-migrations.ts",
    "reset-test-db": "npx --yes tsx scripts/reset-test-db.ts",
    "lint": "eslint . --ext .ts",
    "typecheck": "tsc --noEmit",
    "test:integration": "vitest run --maxWorkers=1",
    "review:protected-handlers": "npx --yes tsx scripts/print-protected-handler-exclusion-summary.ts",
    "review:protected-handlers:json": "npx --yes tsx scripts/print-protected-handler-exclusion-summary-json.ts",
    "review:governance-health": "npx --yes tsx scripts/print-protected-handler-governance-health.ts",
    "verify": "npx --yes tsx scripts/run-quality-gate.ts",
    "verify:ci": "npm run lint && npm run typecheck && npm run migrate && npm run reset-test-db && npm run test:integration"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.1",
    "pg": "^8.13.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.9"
  }
}
